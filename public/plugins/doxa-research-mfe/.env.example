# Copy to .env and fill in a real token before running `npm run dev`.
# Mapbox pk.* tokens are public/browser tokens by design — restrict them to
# your allowed domains in the Mapbox dashboard. Never bake tokens into the
# IIFE bundle (per LL-026); dev-only runtime substitution via Vite is fine.
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Optional: REST API base URL, baked into the IIFE if window.MAP_APP_API_URL
# is not set on the host page. Used by DataSourceManager → loadRestApiData.
VITE_API_BASE_URL=https://pray.doxa.life
