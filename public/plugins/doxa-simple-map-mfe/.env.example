# Copy to .env and fill in a real token before running `npm run dev`.
# Vite substitutes %VITE_MAPBOX_TOKEN% in index.html with the value here.
# Mapbox pk.* tokens are public by design — restrict them to your allowed
# domains in the Mapbox dashboard before committing to a deploy.
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here
VITE_API_BASE_URL=https://pray.doxa.life
