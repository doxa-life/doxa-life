      },
      {
        "type": "paragraph",
        "attrs": {
          "textAlign": null
        },
        "content": [
          {
            "type": "text",
            "text": "Ao utilizar os nossos sites, concorda com as práticas de dados descritas nesta política. Caso não concorde com as práticas descritas nesta política, por favor, não utilize os nossos sites."
          }
        ]
