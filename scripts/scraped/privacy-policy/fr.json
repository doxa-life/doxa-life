      },
      {
        "type": "paragraph",
        "attrs": {
          "textAlign": null
        },
        "content": [
          {
            "type": "text",
            "text": "En utilisant nos sites Web, vous acceptez les pratiques décrites dans la présente politique. Si vous n’acceptez pas les pratiques décrites dans la présente politique, veuillez ne pas utiliser nos sites Web."
          }
