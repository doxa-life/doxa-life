      {
        "type": "paragraph",
        "attrs": {
          "textAlign": null
        },
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "bold"
              }
            ],
            "text": "Время: "
          },
          {
            "type": "text",
            "text": "[Укажите время]"
          }
