        "content": [
          {
            "type": "heading",
            "attrs": {
              "textAlign": null,
              "level": 5
            },
            "content": [
              {
                "type": "text",
                "text": "Para gloria de Dios, hacer discípulos a todas las naciones, yendo, bautizando y enseñando."
              }
            ]
          },
          {
            "type": "heading",
            "attrs": {
              "textAlign": null,
              "level": 5
            },
            "content": [
              {
                "type": "text",
                "text": "– Mateo 28:19-20"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "textAlign": null,
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Prioridad"
          }
        ]
      },
      {
        "type": "paragraph",
        "attrs": {
          "textAlign": null
        },
        "content": [
          {
            "type": "text",
            "text": "Involucrar a todos los grupos étnicos no comprometidos para el año 2.033."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "textAlign": null,
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Valores"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Permanecer en Jesús (Juan 15:5)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Orar sin cesar (1 Tesalonicenses 5:17)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Niégate a ti mismo (Lucas 9:23)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Involucrarse en las regiones más allá (2 Corintios 10:16)"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "textAlign": null,
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Objetivos"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "textAlign": null,
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Oración"
          }
        ]
      },
      {
        "type": "orderedList",
        "attrs": {
          "start": 1,
          "type": null
        },
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Oración diaria por cada una de las 2.085 PNANC"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Al menos 144 intercesores que oran por cada PNANC durante 10 minutos al día (lo que equivale a una cobertura de oración de 24 horas)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Más de 1.000 intercesores por cada PNANC (más de 2.085.000 intercesores)"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "textAlign": null,
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Compromiso"
          }
        ]
      },
      {
        "type": "orderedList",
        "attrs": {
          "start": 1,
          "type": null
        },
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Para 2033, cada grupo étnico no comprometido estará comprometido."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Después de 2033, cada grupo étnico no alcanzado en la Tierra estará comprometido fructíferamente."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Hay una iglesia indígena plantada entre cada grupo étnico en la Tierra."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "textAlign": null,
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "¿Qué significa compromiso?"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Hay una actividad sostenida para compartir a Cristo y hacer discípulos."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Hay esfuerzos para establecer iglesias autosuficientes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "El trabajo se realiza de manera culturalmente apropiada y localmente relevante."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "attrs": {
          "textAlign": null
        },
        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "italic"
              }
            ],
            "text": "* Para la comprensión de la FMAD, esto significa que los trabajadores transculturales son residentes…"
          }
        ]
      }
    ]
