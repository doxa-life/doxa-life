      },
      {
        "type": "div",
        "attrs": {
          "class": "wp-block-group has-doxa-white-color has-brand-light-background-color has-text-color has-background has-link-color wp-elements-20908af68d7bca8a269e83b915f391bf is-layout-flow wp-block-group-is-layout-flow",
