              {
                "type": "text",
                "text": "Une grande multitude de toutes les nations, familles, peuples et langues se tenait devant l’Agneau. "
              }
            ]
          },
          {
            "type": "heading",
            "attrs": {
              "textAlign": null,
              "level": 5
            },
            "content": [
              {
                "type": "text",
                "text": "– Apocalypse 7:9"
              }
            ]
          }
        ]
      },
      {
