          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "La Mission"
          }
        ]
      },
      {
        "type": "div",
        "attrs": {
          "class": "wp-block-group has-doxa-white-color has-brand-light-background-color has-text-color has-background has-link-color wp-elements-35dff377cea816f37aee529feb8cea8e is-layout-flow wp-block-group-is-layout-flow",
