        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Há uma atividade contínua* para compartilhar Cristo e fazer discípulos."
