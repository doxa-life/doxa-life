          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Há uma igreja indígena estabelecida entre cada grupo étnico na Terra."
