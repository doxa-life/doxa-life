              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "1000 intercessores para cada povo não engajado (PNANE) (2.085.000)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "attrs": {
                  "textAlign": null
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Oração contínua de 24 horas por cada povo não engajado (PNANE) em segmentos de 10 minutos"
                  },
                  {
                    "type": "hardBreak"
                  }
                ]
              }
            ]
