{
  "activeSource": "doxa-api",
  "sources": {
    "doxa-csv": {
      "id": "doxa-csv",
      "name": "DOXA CSV Data",
      "type": "csv",
      "path": "assets/data/Joshua-project-ids-Doxa-1439.csv",
      "description": "Local CSV file with 2085 people groups from DOXA",
      "fieldMappings": {
        "uniqueId": ["ROP3", "ROG"],
        "peopleGroupId": "ROP3",
        "countryCode": "ROG",
        "peopleId3": "PeopleID3",
        "name": "Name",
        "displayName": "NmDisp",
        "alternateName": "NmAlt",
        "description": "PeopleDesc",
        "locationDescription": "LocationDe",
        "country": "Ctry",
        "countryIso": "ISOalpha3",
        "region": "Regn",
        "subRegion": "RegnSub",
        "wagfRegion": "WAGF Region",
        "doxaRegion": "WAGF Region",
        "wagfBlock": "WAGF BLOCK",
        "affinityBloc": "Affbloc",
        "affinityBlock": "ROP1",
        "affinityCode": "AffCd",
        "affinityName": "Aff",
        "peopleCluster": "PplClstr",
        "ethneName": "Ethne",
        "latitude": "Latitude",
        "longitude": "Longitude",
        "population": "Pop",
        "populationClass": "PopCls",
        "status": "Status",
        "engagementStatus": "EngStat",
        "evangelicalLevel": "EvngLvl",
        "gsec": "GSEC",
        "gsecBrief": "GSECbrf",
        "gsecLong": "GSEClng",
        "spiScore": "SPI",
        "spiDescription": "SPIdesc",
        "language": "Lang",
        "languageCode": "ROL",
        "languageFamily": "LangFamily",
        "religion": "Rlgn",
        "religionCode": "ROR",
        "religionDescription": "RORdesc",
        "religionBase": "RlgnBs",
        "religionDiv": "RlgnDiv",
        "bible": "Bible",
        "jesusFilm": "Jesus",
        "radio": "Radio",
        "gospel": "Gospel",
        "audio": "Audio",
        "stories": "Stories",
        "resourcesTotal": "ResTot",
        "bibleLevel": "LvlBible",
        "yearPublished": "YrPub",
        "photoCredit": "PicCrdt",
        "photoUrl": "PicURL",
        "hasPhoto": "Photo",
        "isIndigenous": "Indigenous"
      },
      "imageConfig": {
        "useField": "photoUrl",
        "fallbackField": "peopleId3",
        "fallbackUrlTemplate": "https://joshuaproject.net/assets/media/profiles/photos/p{peopleId3}.jpg",
        "placeholderUrl": "https://www.peoplegroups.org/images/pgphotosearch/NoImageAvailable_search.jpg"
      }
    },
    "doxa-api": {
      "id": "doxa-api",
      "name": "DOXA API",
      "type": "api",
      "url": "https://uupg.doxa.life/wp-json/dt-public/disciple-tools-people-groups-api/v1/data/all/",
      "description": "DOXA WordPress API with detailed descriptions and photos",
      "fieldMappings": {
        "uniqueId": "dt_id",
        "peopleGroupId": "dt_id",
        "peopleId3": "",
        "name": "imb_display_name",
        "slug": "slug",
        "description": "imb_people_description",
        "country": "imb_isoalpha3",
        "region": "doxa_wagf_region",
        "wagfRegion": "doxa_wagf_region",
        "doxaRegion": "doxa_wagf_region",
        "wagfBlock": "doxa_wagf_block",
        "latitude": "imb_lat",
        "longitude": "imb_lng",
        "population": "imb_population",
        "religion": "imb_reg_of_religion",
        "religionCode": "imb_reg_of_religion_3",
        "hasPhoto": "imb_has_photo",
        "photoUrl": "imb_picture_url",
        "photoCredit": "imb_picture_credit_html"
      },
      "imageConfig": {
        "useField": "photoUrl",
        "fallbackField": null,
        "fallbackUrlTemplate": null,
        "placeholderUrl": "https://www.peoplegroups.org/images/pgphotosearch/NoImageAvailable_search.jpg"
      }
    },
    "pray-tools": {
      "id": "pray-tools",
      "name": "Prayer.Tools API",
      "type": "rest-api",
      "description": "pray.doxa.life live API — people group prayer, engagement, and adoption data. Base URL read from VITE_API_BASE_URL at build time.",
      "endpoints": {
        "bulk": "/api/people-groups/list",
        "detail": "/api/people-groups/detail/{slug}",
        "statistics": "/api/people-groups/statistics"
      },
      "queryParams": {
        "lang": "en"
      },
      "defaultFields": [
        "slug", "name", "latitude", "longitude",
        "wagf_region", "wagf_block", "wagf_member",
        "rop1", "country_code", "religion",
        "population", "has_photo", "image_url",
        "people_praying", "people_committed", "adopted_by_churches",
        "engagement_status",
        "primary_language"
      ],
      "pollFields": ["slug", "people_praying"],
      "pollInterval": 300000,
      "fallbackSourceId": null,
      "fieldMappings": {
        "uniqueId": "slug",
        "slug": "slug",
        "name": "name",
        "latitude": "latitude",
        "longitude": "longitude",
        "wagfRegion": "wagf_region",
        "doxaRegion": "wagf_region",
        "wagfBlock": "wagf_block",
        "wagfMember": "wagf_member",
        "affinityBlock": "rop1",
        "countryIso": "country_code",
        "religion": "religion",
        "religionCode": "religion",
        "population": "population",
        "hasPhoto": "has_photo",
        "imageUrl": "image_url",
        "photoUrl": "image_url",
        "peoplePraying": "people_praying",
        "peopleCommitted": "people_committed",
        "engagementStatus": "engagement_status",
        "adoptionStatus": "adopted_by_churches",
        "language": "primary_language"
      },
      "imageConfig": {
        "useField": "imageUrl",
        "fallbackField": null,
        "fallbackUrlTemplate": null,
        "placeholderUrl": "https://www.peoplegroups.org/images/pgphotosearch/NoImageAvailable_search.jpg",
        "useSvgPlaceholder": true
      }
    }
  },
  "systemFields": {
    "uniqueId": { "description": "Unique identifier per row (slug for API, ROP3+ROG for CSV)", "required": true },
    "peopleGroupId": { "description": "People group ID — same group can appear in multiple countries", "required": true },
    "name": { "description": "People group display name", "required": true },
    "latitude": { "description": "Latitude coordinate for map pin", "required": true },
    "longitude": { "description": "Longitude coordinate for map pin", "required": true },
    "engagementStatus": { "description": "Boolean — true if people_committed > 0 (someone is engaged/committed to this group)", "required": false },
    "adoptionStatus": { "description": "Boolean — true if adopted_by_churches > 0 (a church has formally adopted this group)", "required": false },
    "peoplePraying": { "description": "Number of people currently praying for this group — from pray-tools API", "required": false },
    "peopleCommitted": { "description": "Raw count of committed workers for this group — source of engagementStatus", "required": false },
    "languageFamily": { "description": "Language family name", "required": false },
    "religion": { "description": "Primary religion", "required": false },
    "population": { "description": "Population count", "required": false },
    "doxaRegion": { "description": "WAGF/DOXA region name", "required": false },
    "photoUrl": { "description": "URL to people group photo", "required": false },
    "description": { "description": "People group description text", "required": false }
  }
}

