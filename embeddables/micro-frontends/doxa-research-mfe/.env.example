# Mapbox public token used at build time for sourcemap reference / dev preview.
# At runtime, the production token is passed via wrapper.html's profile-config.tk
# (per LL-026 — never bake a token into the IIFE bundle).
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9UT0tFTl9IRVJFIn0.placeholder

# Optional: REST API base URL, baked into the IIFE if window.MAP_APP_API_URL
# is not set on the host page. Used by DataSourceManager → loadRestApiData.
VITE_API_BASE_URL=https://pray.doxa.life
